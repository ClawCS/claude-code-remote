# Trinkgut Jammers — Environment Variables
# Copy to .env.local and fill in real values. Never commit .env.local.

# Google Gemini API Key (required for /api/chat, /api/kuehlschrank, /api/leergut-scan)
# Holen unter https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Cron Secret (required for /api/handzettel/cron — schützt automatische Updates)
# Beliebigen sicheren Token generieren, z.B. `openssl rand -hex 32`
CRON_SECRET=
